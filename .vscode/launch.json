{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Vite App in Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "runtimeExecutable": "C:/Program Files/Google/Chrome/Application/chrome.exe",
      "userDataDir": "${workspaceFolder}/.vscode/chrome"
    }
  ],
  "scripts": {
    "dev": "vite --port 5174"
  }
}
